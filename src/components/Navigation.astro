---
import ThemeToggle from "@/components/ThemeToggle.astro";
import { OpenBook, HomeSimple } from "iconoir-react";

const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isHome = pathname === "/";
const isPosts = pathname === "/posts";
const navTitle = isHome ? "HOME" : isPosts ? "BLOG" : Astro.props.navTitle ?? "";
---

<script is:inline>
  const normalizePath = (pathname) => {
    if (!pathname || pathname === "/") {
      return "/";
    }

    return pathname.replace(/\/+$/, "");
  };

  const resolveNavTitle = (pathname) => {
    if (pathname === "/") {
      return "HOME";
    }

    if (pathname === "/posts") {
      return "BLOG";
    }

    return (
      document.querySelector('meta[name="nav-title"]')?.getAttribute("content") ?? ""
    );
  };

  const syncNavigation = () => {
    const pathname = normalizePath(window.location.pathname);
    const homeLink = document.getElementById("home_link");
    const postsLink = document.getElementById("posts_link");
    const navTitle = document.getElementById("nav_title");

    const isHome = pathname === "/";
    const isPosts = pathname === "/posts";

    homeLink?.classList.toggle("dark:opacity-100", isHome);
    homeLink?.classList.toggle("opacity-100", isHome);
    homeLink?.classList.toggle("dark:opacity-30", !isHome);
    homeLink?.classList.toggle("opacity-50", !isHome);

    postsLink?.classList.toggle("dark:opacity-100", isPosts);
    postsLink?.classList.toggle("opacity-100", isPosts);
    postsLink?.classList.toggle("dark:opacity-30", !isPosts);
    postsLink?.classList.toggle("opacity-50", !isPosts);

    if (navTitle) {
      navTitle.textContent = resolveNavTitle(pathname);
    }
  };

  document.addEventListener("astro:page-load", syncNavigation);

  document.addEventListener("swup:enable", () => {
    syncNavigation();
    window.swup?.hooks?.on?.("page:view", syncNavigation);
  });
</script>

<div
  class="container flex flex-row justify-between items-center w-full h-full backdrop-blur-sm 0 bg-sky-600/5 px-5 py-2 rounded-2xl mx-auto border-solid border border-black/5 dark:border-white/5 max-w-screen-lg z-50"
>
  <div class="flex gap-5">
    <a
      id="home_link"
      title="Home"
      data-tooltip-placement="bottom"
      href="/"
      class={`hover:opacity-100 dark:hover:opacity-100 transition-all ${
        isHome ? "dark:opacity-100 opacity-100" : "dark:opacity-30 opacity-50"
      }`}
      aria-label="Home"
    >
      <HomeSimple />
    </a>
    <a
      id="posts_link"
      title="Blog"
      data-tooltip-placement="bottom"
      href="/posts"
      class={`hover:opacity-100 dark:hover:opacity-100 transition-all ${
        isPosts ? "dark:opacity-100 opacity-100" : "dark:opacity-30 opacity-50"
      }`}
      aria-label="Blog"
    >
      <OpenBook />
    </a>
  </div>

  <p
    id="nav_title"
    class="inline text-sm font-extrabold transition-all -ml-7 max-w-28 md:max-w-56 truncate font-archivo"
  >
    {navTitle}
  </p>

  <ThemeToggle />
</div>
