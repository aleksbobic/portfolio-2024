---
import { SunLight, HalfMoon } from "iconoir-react";
import { Button } from "@/components/ui/button";
---

<script is:inline>
  const applyTheme = (theme) => {
    document.documentElement.classList.toggle("dark", theme === "dark");
    window.localStorage.setItem("theme", theme);
  };

  const resolveTheme = () => {
    const storedTheme = window.localStorage.getItem("theme");

    if (storedTheme === "light" || storedTheme === "dark") {
      return storedTheme;
    }

    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light";
  };

  const syncThemeIcon = () => {
    const toggle = document.getElementById("themeToggle");
    const isDark = document.documentElement.classList.contains("dark");

    toggle?.setAttribute(
      "aria-label",
      `Switch to ${isDark ? "light" : "dark"} mode`
    );
  };

  document.addEventListener("click", (event) => {
    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    const toggle = target.closest("#themeToggle");

    if (!toggle) {
      return;
    }

    const nextTheme = resolveTheme() === "dark" ? "light" : "dark";
    applyTheme(nextTheme);
    syncThemeIcon();
  });

  document.addEventListener("astro:page-load", syncThemeIcon);
  syncThemeIcon();
</script>

<Button
  id="themeToggle"
  data-tooltip-placement="bottom"
  variant="ghost"
  size="icon"
  className="text-black dark:text-white dark:opacity-30 opacity-50 hover:opacity-100 dark:hover:opacity-100 transition-all hover:bg-transparent "
  aria-label="Switch to dark mode"
>
  <SunLight className="sun h-[1.2rem] w-[1.2rem] transition-all" />
  <HalfMoon className="moon absolute h-[1.2rem] w-[1.2rem] transition-all" />
</Button>

<style>
  .sun {
    display: block;
  }

  .moon {
    display: none;
  }

  :global(.dark) .sun {
    display: none;
  }

  :global(.dark) .moon {
    display: block;
  }
</style>
