---
import Navigation from "@/components/Navigation.astro";
import "@fontsource/poppins/400.css";
import "@fontsource/poppins/600.css";
import "@fontsource/poppins/500.css";
import "@fontsource/poppins/700.css";
import "@fontsource-variable/archivo";

interface Props {
  title: string;
  description?: string;
  navTitle?: string;
}

const defaultDescription =
  "Hi I'm Aleks, a seasoned software engineer and researcher with multiple years of experience in software engineering, data science and research.";

const {
  title,
  description = defaultDescription,
  navTitle = title,
} = Astro.props as Props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="nav-title" content={navTitle} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const storedTheme = window.localStorage.getItem("theme");
        const theme =
          storedTheme === "light" || storedTheme === "dark"
            ? storedTheme
            : window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";

        document.documentElement.classList.toggle("dark", theme === "dark");
        window.localStorage.setItem("theme", theme);
      })();
    </script>
  </head>
  <body class="pt-28">
    <header class="fixed top-1 px-5 py-4 w-full z-50">
      <Navigation navTitle={navTitle} />
    </header>
    <slot />

    <footer
      class="container flex flex-col gap-2 justify-center items-center w-full px-5 py-2 mt-20 mb-20 mx-auto max-w-screen-lg font-bold"
    >
      <a
        class="opacity-50 hover:opacity-100 transition-all hover:cursor-pointer font-archivo"
        href="/"
      >
        Home
      </a>

      <a
        class="opacity-50 hover:opacity-100 transition-all hover:cursor-pointer font-archivo"
        href="/posts"
      >
        Blog
      </a>
      <div class="flex gap-2">
        <p class="opacity-50 hover:opacity-100 transition-all font-archivo">
          contact
        </p>
        <p class="opacity-50 hover:opacity-100 transition-all font-archivo">
          at
        </p>
        <p class="opacity-50 hover:opacity-100 transition-all font-archivo">
          abobic
        </p>
        <p class="opacity-50 hover:opacity-100 transition-all font-archivo">
          dot
        </p>
        <p class="opacity-50 hover:opacity-100 transition-all font-archivo">
          com
        </p>
      </div>
    </footer>
  </body>
</html>
